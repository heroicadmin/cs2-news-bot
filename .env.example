# Copy this file to .env and fill in your values.

# Required: Your Discord channel webhook URL
# Create one: Channel Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Optional: How often to poll feeds, in seconds (default: 60)
POLL_INTERVAL_SECONDS=60

# Optional: Path to the SQLite dedup database (default: seen_items.db)
DB_PATH=seen_items.db
